<Window x:Class="OOPWPFProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Система обліку замовлень"
        Background="#1A2235" WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="Padding" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#3A4A6A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="#2A3555"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="CaretBrush" Value="#C6A75E"/>
            <Setter Property="SelectionBrush" Value="#C6A75E"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#C6A75E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="Background" Value="#2A3555"/>
            <Setter Property="BorderBrush" Value="#3A4A6A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="#2A3555"
                                BorderBrush="#3A4A6A"
                                BorderThickness="1.5"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Foreground="#E8DCC8"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Padding="8,6"
                                                   CaretBrush="#C6A75E"
                                                   SelectionBrush="#C6A75E"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Focusable="False">
                                    <TextBlock Text="📅" FontSize="14" Foreground="#C6A75E"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <Popup x:Name="PART_Popup"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#2E3D5C"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="Background" Value="#2A3555"/>
            <Setter Property="BorderBrush" Value="#3A4A6A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="#2A3555"
                                          BorderBrush="#3A4A6A"
                                          BorderThickness="1.5"
                                          Foreground="#E8DCC8"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="8,6"/>
                                                <TextBlock Grid.Column="1" Text="▾"
                                                           Foreground="#C6A75E"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,6,28,6"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#E8DCC8"/>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220">
                                    <Border Background="#2A3555"
                                            BorderBrush="#C6A75E"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#2A3555"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextBlock.Foreground="#E8DCC8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A4A6A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C6A75E"/>
                                <Setter Property="Foreground" Value="#1A2235"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1F2A44"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="BorderBrush" Value="#2E3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E3D5C"/>
            <Setter Property="RowBackground" Value="#1F2A44"/>
            <Setter Property="AlternatingRowBackground" Value="#243050"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="RowHeight" Value="32"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#162030"/>
            <Setter Property="Foreground" Value="#C6A75E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#2E3D5C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E4A7A"/>
                    <Setter Property="Foreground" Value="#E8DCC8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2E4A7A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#253560"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8A9BBE"/>
            <Setter Property="Padding" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#C6A75E"/>
            <Setter Property="Foreground" Value="#1A2235"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#D4B870"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#B8953A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C6A75E"/>
            <Setter Property="BorderBrush" Value="#C6A75E"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1A2D50"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#243050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#762E3F"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#8F3A4D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#5C2230"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2E7653"/>
            <Setter Property="Foreground" Value="#E8DCC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3A9468"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ БІЧНА ПАНЕЛЬ ═══ -->
        <Border Grid.Column="0" Background="#162030">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,32">
                    <TextBlock Text="📦" FontSize="36" Margin="0,0,0,10"/>
                    <TextBlock Text="Облік" FontSize="22" FontWeight="Bold"
                               Foreground="#C6A75E" FontFamily="Segoe UI"/>
                    <TextBlock Text="замовлень" FontSize="22" FontWeight="Bold"
                               Foreground="#E8DCC8" FontFamily="Segoe UI"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <Border Background="#1F2A44" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="ПОТОЧНИЙ КОРИСТУВАЧ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="CurrentUserBlock" Text="—" FontSize="15" FontWeight="Bold"
                                       Foreground="#C6A75E" FontFamily="Segoe UI" Margin="0,4,0,2"/>
                            <TextBlock x:Name="CurrentRoleBlock" Text="—" FontSize="11"
                                       Foreground="#8A9BBE" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Button Content="🚪 Вийти з акаунту"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Click="Logout_Click"/>
                    <Border Background="#1F2A44" CornerRadius="10" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="ВСЬОГО ЗАМОВЛЕНЬ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TotalCountBlock" Text="0" FontSize="32"
                                       FontWeight="Bold" Foreground="#C6A75E" FontFamily="Segoe UI"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="12,0">
                    <Border x:Name="NavOrders" Background="#C6A75E" CornerRadius="8"
                            Margin="0,0,0,6" Cursor="Hand" MouseDown="NavOrders_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,12">
                            <TextBlock Text="≡" FontSize="17" Foreground="#1A2235"
                                       FontFamily="Segoe UI" Margin="0,0,12,0"/>
                            <TextBlock Text="Замовлення" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#1A2235" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="NavOps" Background="Transparent" CornerRadius="8"
                            Margin="0,0,0,6" Cursor="Hand" MouseDown="NavOps_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,12">
                            <TextBlock Text="⚡" FontSize="17" Foreground="#8A9BBE"
                                       FontFamily="Segoe UI" Margin="0,0,12,0"/>
                            <TextBlock Text="Операції" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#8A9BBE" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="NavStats" Background="Transparent" CornerRadius="8"
                            Margin="0,0,0,6" Cursor="Hand" MouseDown="NavStats_Click">
                        <StackPanel Orientation="Horizontal" Margin="16,12">
                            <TextBlock Text="📊" FontSize="17" Foreground="#8A9BBE"
                                       FontFamily="Segoe UI" Margin="0,0,12,0"/>
                            <TextBlock Text="Статистика" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#8A9BBE" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ ОСНОВНИЙ КОНТЕНТ ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── СТОРІНКА ЗАМОВЛЕНЬ ─── -->
            <Grid x:Name="PageOrders" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Margin="28,24,14,24">

                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Список замовлень" FontSize="20" FontWeight="SemiBold"
                                   Foreground="#E8DCC8" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Сортувати:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="SortComboBox" Width="150"
                                      SelectionChanged="SortComboBox_SelectionChanged">
                                <ComboBoxItem Content="Назвою товару"/>
                                <ComboBoxItem Content="Кількістю"/>
                                <ComboBoxItem Content="Ціною"/>
                                <ComboBoxItem Content="Сумою"/>
                                <ComboBoxItem Content="Датою"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border DockPanel.Dock="Top" Background="#162030" CornerRadius="8"
                            Padding="14,10" Margin="0,0,0,10">
                        <WrapPanel>
                            <TextBlock Text="🔍" FontSize="14" Foreground="#8A9BBE"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="SearchBox" Width="200" Margin="0,0,14,0"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="Статус:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterStatusComboBox" Width="140" Margin="0,0,12,0"
                                      SelectionChanged="FilterStatus_Changed">
                                <ComboBoxItem Content="Всі" IsSelected="True"/>
                                <ComboBoxItem Content="Нове"/>
                                <ComboBoxItem Content="В обробці"/>
                                <ComboBoxItem Content="Доставлено"/>
                                <ComboBoxItem Content="Готове до видачі"/>
                                <ComboBoxItem Content="Скасовано"/>
                            </ComboBox>
                            <TextBlock Text="Тип:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FilterTypeComboBox" Width="130" Margin="0,0,12,0"
                                      SelectionChanged="FilterType_Changed">
                                <ComboBoxItem Content="Всі" IsSelected="True"/>
                                <ComboBoxItem Content="Онлайн"/>
                                <ComboBoxItem Content="Магазин"/>
                            </ComboBox>
                            <Button Content="✕ Скинути" Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" Click="ResetFilters_Click"/>
                        </WrapPanel>
                    </Border>

                    <!-- Тост над кнопками -->
                    <Border DockPanel.Dock="Bottom" x:Name="ToastBorder" Background="#2E7653"
                            CornerRadius="8" Padding="12,10" Margin="0,4,0,0"
                            Visibility="Collapsed" HorizontalAlignment="Right">
                        <TextBlock x:Name="ToastText" Text=""
                                   Foreground="#E8DCC8" FontFamily="Segoe UI" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Кнопки дій -->
                    <WrapPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                        <Button x:Name="DeleteButton" Content="🗑 Видалити"
                                Style="{StaticResource DangerButton}"
                                Margin="0,0,8,0" Click="DeleteRecord_Click"/>
                        <ComboBox x:Name="StatusComboBox" Width="150" Margin="0,0,8,0">
                            <ComboBoxItem Content="Нове"/>
                            <ComboBoxItem Content="В обробці"/>
                            <ComboBoxItem Content="Доставлено"/>
                            <ComboBoxItem Content="Готове до видачі"/>
                            <ComboBoxItem Content="Скасовано"/>
                        </ComboBox>
                        <Button Content="✔ Оновити статус"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="UpdateStatus_Click"/>
                        <Button x:Name="SaveDeliveredButton" Content="💾 Зберегти доставлені"
                                Style="{StaticResource SuccessButton}"
                                Margin="0,0,8,0" Click="SaveDelivered_Click"/>
                        <Button x:Name="ExportCsvButton" Content="📤 Експорт CSV"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="ExportCsv_Click"/>
                        <Button Content="🧾 Чек (PDF)"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,9"
                                Click="GenerateReceipt_Click"/>
                    </WrapPanel>

                    <!-- Пошук за індексом -->
                    <Border DockPanel.Dock="Bottom" Background="#162030" CornerRadius="8"
                            Padding="14,10" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <WrapPanel VerticalAlignment="Center">
                                <TextBlock Text="Індекс:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="IndexTextBox" Width="60" Margin="0,0,8,0"/>
                                <Button x:Name="ShowIndexButton" Content="Показати"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,6" Click="ShowByIndex_Click"/>
                            </WrapPanel>
                            <TextBlock x:Name="IndexResultBlock" Grid.Column="1"
                                       Visibility="Collapsed"
                                       TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#C6A75E" Margin="16,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Таблиця -->
                    <DataGrid x:Name="OrdersDataGrid"
                              ItemsSource="{Binding Orders}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"            Binding="{Binding Index}"                               Width="50"/>
                            <DataGridTextColumn Header="Назва товару" Binding="{Binding ProductName}"                         Width="*"/>
                            <DataGridTextColumn Header="К-сть"        Binding="{Binding Quantity}"                            Width="60"/>
                            <DataGridTextColumn Header="Ціна"         Binding="{Binding Price, StringFormat=F2}"              Width="80"/>
                            <DataGridTextColumn Header="Сума"         Binding="{Binding Total, StringFormat=F2}"              Width="90"/>
                            <DataGridTextColumn Header="Статус"       Binding="{Binding OrderState}"                         Width="120"/>
                            <DataGridTextColumn Header="Кур'єр"       Binding="{Binding AssignedCourier}"                    Width="100"/>
                            <DataGridTextColumn Header="Дата"         Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Готове"       Binding="{Binding ReadyForPickup}"                     Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>

                <!-- Форма справа -->
                <Border Grid.Column="1" Background="#162030">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,24,24,24">

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="FormTitle" Text="Нове замовлення" FontSize="17"
                                           FontWeight="SemiBold" Foreground="#E8DCC8"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                <Button x:Name="EditModeButton" Grid.Column="1" Content="🖊"
                                        ToolTip="Редагувати виділене замовлення"
                                        Style="{StaticResource SecondaryButton}" Padding="10,6"
                                        Click="EditMode_Click"/>
                            </Grid>

                            <Label Content="ТИП ЗАМОВЛЕННЯ" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton x:Name="RadioOnline" Content="Онлайн"
                                             IsChecked="True" Checked="RadioButton_Checked"/>
                                <RadioButton x:Name="RadioStore" Content="Магазин"
                                             Checked="RadioButton_Checked"/>
                            </StackPanel>

                            <Label Content="ОСНОВНІ ДАНІ" Style="{StaticResource SectionLabel}"/>
                            <Label Content="Назва товару"/>
                            <TextBox x:Name="textboxName"/>
                            <Label Content="Кількість"/>
                            <TextBox x:Name="textboxQuantity"/>
                            <Label Content="Ціна (грн)"/>
                            <TextBox x:Name="textboxPrice"/>
                            <Label Content="Дата замовлення"/>
                            <DatePicker x:Name="textboxCreatedAt" Margin="0,0,0,10"/>

                            <Separator Margin="0,6,0,14"/>
                            <Label Content="ДЕТАЛІ ДОСТАВКИ" Style="{StaticResource SectionLabel}"/>

                            <StackPanel x:Name="PanelOnline">
                                <Label Content="Адреса доставки"/>
                                <TextBox x:Name="textboxDeliveryAddress"/>
                                <Label Content="Номер відстеження"/>
                                <TextBox x:Name="textboxTrackingNumber"/>
                                <Label Content="Кур'єр"/>
                                <TextBox x:Name="textboxCourier"/>
                            </StackPanel>

                            <StackPanel x:Name="PanelStore" Visibility="Collapsed">
                                <Label Content="Місце магазину"/>
                                <TextBox x:Name="textboxStoreLocation"/>
                                <Label Content="Час отримання"/>
                                <TextBox x:Name="textboxPickupTime"/>
                                <Label Content="Кур'єр"/>
                                <TextBox x:Name="textboxCourierStore"/>
                            </StackPanel>

                            <Separator Margin="0,6,0,14"/>

                            <Button x:Name="AddButton" Content="＋  Додати замовлення"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,0,10" HorizontalAlignment="Stretch"
                                    Click="AddRecord_Click"/>
                            <Button x:Name="CancelEditButton" Content="✕ Скасувати редагування"
                                    Style="{StaticResource DangerButton}"
                                    Margin="0,0,0,10" HorizontalAlignment="Stretch"
                                    Visibility="Collapsed"
                                    Click="CancelEdit_Click"/>
                            <Button Content="Очистити форму"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Click="ClearForm_Click"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ─── СТОРІНКА ОПЕРАЦІЙ ─── -->
            <Grid x:Name="PageOps" Grid.Row="0" Visibility="Collapsed">
                <StackPanel Margin="36,28,36,20">
                    <TextBlock Text="Операції над замовленнями" FontSize="20" FontWeight="SemiBold"
                               Foreground="#E8DCC8" FontFamily="Segoe UI" Margin="0,0,0,24"/>

                    <Border Background="#162030" CornerRadius="10" Padding="28,22" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="АРИФМЕТИЧНІ ОПЕРАЦІЇ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5A7A" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Індекс A" Foreground="#8A9BBE"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="IndexATextBox" Width="90"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Індекс B" Foreground="#8A9BBE"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="IndexBTextBox" Width="90"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,10">
                                    <Button Content="A + B" Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0" Click="OperatorAdd_Click"/>
                                    <Button Content="A − B" Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,0" Click="OperatorSub_Click"/>
                                    <Button Content="A &gt; B ?" Style="{StaticResource SecondaryButton}"
                                            Click="OperatorGreater_Click"/>
                                </StackPanel>
                            </WrapPanel>
                            <Border x:Name="OperatorResultBorder" Background="#1F2A44" CornerRadius="8"
                                    Padding="16,12" Margin="0,10,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="OperatorResultBlock" TextWrapping="Wrap"
                                           FontFamily="Segoe UI" FontSize="13" Foreground="#C6A75E"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#162030" CornerRadius="10" Padding="28,22">
                        <StackPanel>
                            <TextBlock Text="ПОШУК ЗА ІНДЕКСОМ" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5A7A" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                            <WrapPanel>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Індекс" Foreground="#8A9BBE"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <TextBox x:Name="IndexSearchTextBox" Width="90"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
                                    <Button Content="Знайти" Style="{StaticResource SecondaryButton}"
                                            Click="ShowByIndex_Click2"/>
                                </StackPanel>
                            </WrapPanel>
                            <Border x:Name="SearchResultBorder" Background="#1F2A44" CornerRadius="8"
                                    Padding="16,12" Margin="0,10,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="SearchResultBlock" TextWrapping="Wrap"
                                           FontFamily="Segoe UI" FontSize="13" Foreground="#C6A75E"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ─── СТОРІНКА СТАТИСТИКИ ─── -->
            <Grid x:Name="PageStats" Grid.Row="0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="36,28,36,20">

                        <TextBlock Text="Статистика замовлень" FontSize="20" FontWeight="SemiBold"
                                   Foreground="#E8DCC8" FontFamily="Segoe UI" Margin="0,0,0,20"/>

                        <Border Background="#162030" CornerRadius="8" Padding="18,14" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="ФІЛЬТР ЗА ДАТОЮ" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#4A5A7A" FontFamily="Segoe UI" Margin="0,0,0,12"/>
                                <WrapPanel VerticalAlignment="Center">
                                    <TextBlock Text="З:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <DatePicker x:Name="StatDateFrom" Width="140" Margin="0,0,18,0"/>
                                    <TextBlock Text="По:" Foreground="#8A9BBE" FontFamily="Segoe UI"
                                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <DatePicker x:Name="StatDateTo" Width="140" Margin="0,0,18,0"/>
                                    <Button Content="Застосувати" Style="{StaticResource PrimaryButton}"
                                            Padding="14,8" Margin="0,0,8,0"
                                            Click="StatApplyFilter_Click"/>
                                    <Button Content="Скинути" Style="{StaticResource SecondaryButton}"
                                            Padding="14,8" Click="StatResetFilter_Click"/>
                                </WrapPanel>
                                <TextBlock x:Name="StatPeriodLabel" Text=""
                                           Foreground="#8A9BBE" FontFamily="Segoe UI" FontSize="12"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0,0,0,20">
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="ЗАГАЛЬНА СУМА" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatTotalSum" Text="0.00 грн"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#C6A75E" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="ВСЬОГО ЗАМОВЛЕНЬ" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatTotalCount" Text="0"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#C6A75E" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="ОНЛАЙН" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatOnlineCount" Text="0"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#2E7653" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="В МАГАЗИНІ" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatStoreCount" Text="0"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#762E3F" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="ДОСТАВЛЕНО" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatDeliveredCount" Text="0"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#2E7653" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#162030" CornerRadius="10" Padding="22,18"
                                    Margin="0,0,14,14" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="СЕРЕДНЯ СУМА" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4A5A7A" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="StatAvgSum" Text="0.00 грн"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#C6A75E" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Background="#162030" CornerRadius="10" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="РОЗПОДІЛ ПО СТАТУСАХ" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#4A5A7A" FontFamily="Segoe UI" Margin="0,0,0,16"/>
                                <ItemsControl x:Name="StatStatusList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#E8DCC8" FontFamily="Segoe UI"
                                                           FontSize="13" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="#2A3555"
                                                        CornerRadius="4" Height="8" Margin="0,0,14,0">
                                                    <Border Background="#C6A75E" CornerRadius="4"
                                                            HorizontalAlignment="Left"
                                                            Width="{Binding BarWidth}"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                           Foreground="#C6A75E" FontFamily="Segoe UI"
                                                           FontSize="13" HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- StatusBar -->
            <Border Grid.Row="1" Background="#111825" Padding="28,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusBlock" Text="Готово"
                               Foreground="#4A5A7A" FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="StatusCountBlock"
                               Foreground="#4A5A7A" FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>